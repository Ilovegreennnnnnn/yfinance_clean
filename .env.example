# Example environment variables for deployment (do NOT store secrets in Git)
# Copy this to .env on the VM and fill with real values.

ORACLE_USER=ADMIN
ORACLE_PASSWORD=changeme
ORACLE_DSN=mondb_tp
ORACLE_WALLET_PATH=/wallet
ORACLE_WALLET_PASSWORD=wallet_password_here

# VM and deploy settings (for GitHub Secrets, not this file)
# VM_HOST, VM_USER, VM_SSH_KEY should be set in GitHub Secrets
